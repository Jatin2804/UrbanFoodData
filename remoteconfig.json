      {
        "id": "offer_1",
        "localAsset": "offer_carousel_1",
        "show": true
      },
      {
        "id": "offer_2",
        "localAsset": "offer_carousel_2",
        "show": true
      },
      {
        "id": "offer_3",
        "localAsset": "offer_carousel_3",
